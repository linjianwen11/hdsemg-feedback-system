<Window x:Class="EMGFeedbackSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:EMGFeedbackSystem.Converters"
        Title="肌电反馈系统"
        Width="1000"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:NullOrEmptyToDefaultConverter x:Key="NullOrEmptyToDefaultConverter"/>
        <converters:PercentToOffsetConverter x:Key="PercentToOffsetConverter"/>
    </Window.Resources>

    <Grid Background="#DDDDDD">
        <Border BorderBrush="Black" BorderThickness="1" Margin="40">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部按钮区域 -->
                <Border BorderBrush="Black" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Margin="20,5,0,0">
                        <Button Content="连接采集设备" Width="120" Height="35" Margin="10,0" Command="{Binding ConnectCommand}"/>
                        <Button Content="启动采集" Width="100" Height="35" Margin="10,0" Command="{Binding StartCollectionCommand}"/>
                        <Button Content="停止采集" Width="100" Height="35" Margin="10,0" Command="{Binding StopCollectionCommand}"/>
                    </StackPanel>
                </Border>

                <!-- 主体区域 -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="4.1*"/>
                        <ColumnDefinition Width="2.4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧按钮菜单 -->
                    <Border BorderBrush="Black" BorderThickness="0,0,1,0">
                        <UniformGrid Columns="1" Rows="10" Margin="10">

                            <Button Click="SubjectNameButton_Click">
                                <TextBlock Text="{Binding SubjectName, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='受试者姓名'}"/>
                            </Button>
                            <Button Click="SubjectGenderButton_Click">
                                <TextBlock Text="{Binding SelectedGender, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='受试者性别'}"/>
                            </Button>
                            <Button Click="SubjectAgeButton_Click">
                                <TextBlock Text="{Binding SubjectAge, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='受试者年龄'}"/>
                            </Button>
                            <Button Click="SubjectIdButton_Click">
                                <TextBlock Text="{Binding SubjectId, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='受试者编号'}"/>
                            </Button>
                            <Button Click="SubjectNotesButton_Click">
                                <TextBlock Text="{Binding SubjectNotes, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='受试者备注'}"/>
                            </Button>
                            <Button Click="ElectrodePositionButton_Click">
                                <TextBlock Text="{Binding SelectedLegPosition, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='电极粘贴部位'}"/>
                            </Button>
                            <Button Click="LegSideButton_Click">
                                <TextBlock Text="{Binding SelectedLegSide, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='该腿为(健侧/患侧)'}"/>
                            </Button>
                            <Button Click="UpperLimitButton_Click">
                                <TextBlock Text="{Binding UpperLimitText, Converter={StaticResource NullOrEmptyToDefaultConverter}, ConverterParameter='设置上限基准'}"/>
                            </Button>
                            <Button Content="读取数据" Command="{Binding LoadSubjectCommand}"/>
                            <Button Content="存储数据" Command="{Binding SaveSubjectCommand}"/>

                        </UniformGrid>
                    </Border>

                    <!-- 中间热力图区域 -->
                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 左右腿选择 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <RadioButton Content="左腿" IsChecked="{Binding IsLeftLegSelected}" Margin="20,5"/>
                                <RadioButton Content="右腿" IsChecked="{Binding IsRightLegSelected}" Margin="20,5"/>
                            </StackPanel>

                            <!-- 三个热力图（7x3网格）+ 进度条 + 数值 -->
                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- A电极 -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="15">
                                    <TextBlock Text="A电极" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <Border BorderBrush="Black" BorderThickness="1" Width="90" Height="210" Margin="5">
                                        <Image Source="{Binding CenterHeatmapA}" Stretch="Uniform"/>
                                    </Border>
                                    <Grid Width="90" Height="20" Margin="0,5">
                                        <ProgressBar Value="{Binding ProgressBarValueA}" Maximum="100" Foreground="{Binding ProgressBarColorA}"/>
                                        <Canvas IsHitTestVisible="False">
                                            <Border Width="2" Height="20" Background="Black">
                                                <Border.RenderTransform>
                                                    <TranslateTransform>
                                                        <TranslateTransform.X>
                                                            <MultiBinding Converter="{StaticResource PercentToOffsetConverter}">
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                                <Binding Path="ComparisonMarkerA"/>
                                                            </MultiBinding>
                                                        </TranslateTransform.X>
                                                    </TranslateTransform>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Canvas>
                                    </Grid>
                                    <TextBlock Text="{Binding TextBlockValueA}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>

                                <!-- B电极 -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="15">
                                    <TextBlock Text="B电极" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <Border BorderBrush="Black" BorderThickness="1" Width="90" Height="210" Margin="5">
                                        <Image Source="{Binding CenterHeatmapB}" Stretch="Uniform"/>
                                    </Border>
                                    <Grid Width="90" Height="20" Margin="0,5">
                                        <ProgressBar Value="{Binding ProgressBarValueB}" Maximum="100" Foreground="{Binding ProgressBarColorB}"/>
                                        <Canvas IsHitTestVisible="False">
                                            <Border Width="2" Height="20" Background="Black">
                                                <Border.RenderTransform>
                                                    <TranslateTransform>
                                                        <TranslateTransform.X>
                                                            <MultiBinding Converter="{StaticResource PercentToOffsetConverter}">
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                                <Binding Path="ComparisonMarkerB"/>
                                                            </MultiBinding>
                                                        </TranslateTransform.X>
                                                    </TranslateTransform>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Canvas>
                                    </Grid>
                                    <TextBlock Text="{Binding TextBlockValueB}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>

                                <!-- C电极 -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="15">
                                    <TextBlock Text="C电极" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <Border BorderBrush="Black" BorderThickness="1" Width="90" Height="210" Margin="5">
                                        <Image Source="{Binding CenterHeatmapC}" Stretch="Uniform"/>
                                    </Border>
                                    <Grid Width="90" Height="20" Margin="0,5">
                                        <ProgressBar Value="{Binding ProgressBarValueC}" Maximum="100" Foreground="{Binding ProgressBarColorC}"/>
                                        <Canvas IsHitTestVisible="False">
                                            <Border Width="2" Height="20" Background="Black">
                                                <Border.RenderTransform>
                                                    <TranslateTransform>
                                                        <TranslateTransform.X>
                                                            <MultiBinding Converter="{StaticResource PercentToOffsetConverter}">
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                                <Binding Path="ComparisonMarkerC"/>
                                                            </MultiBinding>
                                                        </TranslateTransform.X>
                                                    </TranslateTransform>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Canvas>
                                    </Grid>
                                    <TextBlock Text="{Binding TextBlockValueC}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 右侧柱状图区 -->
                    <Grid Grid.Column="2" Margin="10">

                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- A -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Button Content="当前有效值A" Height="40" Margin="5"/>
                                <Button Content="最大有效值A" Height="40" Margin="5"/>
                                <Border BorderBrush="Black" BorderThickness="1" Width="80" Height="280" Margin="5">
                                    <Image Source="{Binding HeatmapA}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>

                            <!-- B -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <Button Content="当前有效值B" Height="40" Margin="5"/>
                                <Button Content="最大有效值B" Height="40" Margin="5"/>
                                <Border BorderBrush="Black" BorderThickness="1" Width="80" Height="280" Margin="5">
                                    <Image Source="{Binding HeatmapB}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>

                            <!-- C -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Button Content="当前有效值C" Height="40" Margin="5"/>
                                <Button Content="最大有效值C" Height="40" Margin="5"/>
                                <Border BorderBrush="Black" BorderThickness="1" Width="80" Height="280" Margin="5">
                                    <Image Source="{Binding HeatmapC}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
